# Public
NEXT_PUBLIC_APP_URL=<http://localhost:3000>
NEXT_PUBLIC_API_PREFIX=/api/v1
NEXT_PUBLIC_VERSION=1.0.0

# Atlas 
MONGODB=<your_mongodb_connection_string>

# LLM (server-only — never expose to client)
OPENAI_API_KEY=<your_openai_api_key>
# Optional: override for OpenAI-compatible endpoints (Ollama, Together AI, etc.)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4.1-mini

# Cloudinary (server-only — never expose to client)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

SUNO_API_KEY=                    # optional — enables SunoAI API generation in step 4

# Secret
NEXTAUTH_URL=<http://localhost:3000>
NEXTAUTH_SECRET=<your_next_auth_secret>
CRON_SECRET=<your_cron_secret>
BCRYPT_SALT_ROUND=<10>
