# Public
NEXT_PUBLIC_APP_URL=<http://localhost:3000>
NEXT_PUBLIC_API_PREFIX=/api/v1
NEXT_PUBLIC_VERSION=1.0.0


# Atlas 
MONGODB=<your_mongodb_connection_string>

# LLM (server-only — never expose to client)
OPENAI_API_KEY=<your_openai_api_key>
# Optional: override for OpenAI-compatible endpoints (Ollama, Together AI, etc.)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4.1-mini

# Suno
SUNO_API_KEY=<your_suno_api_key>
SUNO_API_BASE_URL=<your_suno_api_base_url>

# Cloudinary (API secret is server-only; cloud name is also in NEXT_PUBLIC_* for step 7 UI validation)
# Same value as CLOUDINARY_CLOUD_NAME — step 7 validates prompt image URLs against your account
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Secret
# Required in production: same value you pass once as ?token=... then stored in sessionStorage;
# sent as Authorization: Bearer on /api/v1/* from the browser.
API_SECRET=<long_random_string>
NEXTAUTH_URL=<http://localhost:3000>
NEXTAUTH_SECRET=<your_next_auth_secret>
CRON_SECRET=<your_cron_secret>
BCRYPT_SALT_ROUND=<10>
API_SECRET=<your_api_secret>